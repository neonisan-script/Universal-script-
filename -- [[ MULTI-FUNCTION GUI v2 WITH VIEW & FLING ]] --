--- [[ LOGIC ]] ---

local lp = game.Players.LocalPlayer
local camera = workspace.CurrentCamera

-- Fungsi Cari Player berdasarkan Singkatan
local function getPlayer(name)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():sub(1, #name) == name:lower() or v.DisplayName:lower():sub(1, #name) == name:lower() then
            return v
        end
    end
end

-- 1. View Player
local viewing = false
ViewBtn.MouseButton1Click:Connect(function()
    local target = getPlayer(NameInput.Text)
    if target and target.Character then
        viewing = not viewing
        if viewing then
            camera.CameraSubject = target.Character.Humanoid
            ViewBtn.Text = "Unview"
        else
            camera.CameraSubject = lp.Character.Humanoid
            ViewBtn.Text = "View Player"
        end
    end
end)

-- 2. Fling Player (Metode Rotasi Cepat)
FlingBtn.MouseButton1Click:Connect(function()
    local target = getPlayer(NameInput.Text)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = lp.Character.HumanoidRootPart
        local targetHrp = target.Character.HumanoidRootPart
        
        -- Simpan posisi asli
        local oldPos = hrp.CFrame
        
        -- Kecepatan rotasi gila untuk efek fling
        local velocity = Instance.new("BodyAngularVelocity", hrp)
        velocity.AngularVelocity = Vector3.new(0, 99999, 0)
        velocity.MaxTorque = Vector3.new(0, 99999, 0)
        velocity.P = 99999
        
        -- Teleport ke target sebentar untuk menabraknya
        hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, 0.5)
        wait(0.2)
        hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, -0.5)
        wait(0.1)
        
        -- Balik ke posisi awal dan hapus efek
        velocity:Destroy()
        hrp.CFrame = oldPos
    end
end)

-- Fitur lainnya (Fly, Noclip, dll tetap sama dengan script sebelumnya)
-- [Fly Logic]
local flying = false
FlyBtn.MouseButton1Click:Connect(function()
    flying = not flying
    if flying then
        local bv = Instance.new("BodyVelocity", lp.Character.HumanoidRootPart)
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        spawn(function()
            while flying do
                wait()
                bv.Velocity = camera.CFrame.LookVector * 100
                lp.Character.Humanoid.PlatformStand = true
            end
            bv:Destroy()
            lp.Character.Humanoid.PlatformStand = false
        end)
    end
end)

