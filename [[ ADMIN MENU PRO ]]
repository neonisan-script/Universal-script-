-- Fungsi Helper Mencari Player
local function getPlayer(name)
	for _, p in pairs(game.Players:GetPlayers()) do
		if p.Name:lower():sub(1, #name) == name:lower() then
			return p
		end
	end
end

local function createButton(name, color, callback)
	local btn = Instance.new("TextButton")
	btn.Parent = Container
	btn.Size = UDim2.new(0.9, 0, 0, 35)
	btn.Text = name
	btn.BackgroundColor3 = color
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Font = Enum.Font.SourceSansBold
	btn.MouseButton1Click:Connect(callback)
	return btn
end

-- [[ FITUR FLING & VIEW ]] --

-- 1. VIEW PLAYER
local viewing = false
createButton("View / Unview", Color3.fromRGB(70, 130, 180), function()
	if viewing then
		camera.CameraSubject = player.Character.Humanoid
		viewing = false
	else
		local target = getPlayer(TargetInput.Text)
		if target and target.Character then
			camera.CameraSubject = target.Character.Humanoid
			viewing = true
		end
	end
end)

-- 2. FLING PLAYER (Spin Fling)
local flinging = false
createButton("Fling Target", Color3.fromRGB(220, 20, 60), function()
	local target = getPlayer(TargetInput.Text)
	if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
		flinging = not flinging
		
		local hrp = player.Character.HumanoidRootPart
		local originalCFrame = hrp.CFrame
		
		local velocity = Instance.new("AngularVelocity")
		velocity.Parent = hrp
		velocity.MaxTorque = math.huge
		velocity.AngularVelocity = Vector3.new(0, 99999, 0) -- Putaran super cepat
		
		task.spawn(function()
			while flinging and target.Character do
				hrp.CFrame = target.Character.HumanoidRootPart.CFrame
				task.wait()
			end
			velocity:Destroy()
			hrp.CFrame = originalCFrame
		end)
	end
end)

-- 3. FLY (Simple Camera Fly)
local flying = false
createButton("Fly", Color3.fromRGB(60, 179, 113), function()
	flying = not flying
	local bv = Instance.new("BodyVelocity", player.Character.HumanoidRootPart)
	bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	task.spawn(function()
		while flying do
			bv.Velocity = camera.CFrame.LookVector * 100
			task.wait()
		end
		bv:Destroy()
	end)
end)

-- 4. INF JUMP
createButton("Inf Jump", Color3.fromRGB(100, 100, 100), function()
