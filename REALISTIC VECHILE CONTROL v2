--[[ 
    REALISTIC VEHICLE CONTROL v2
    Fitur: Speed, Turbo (E), Drift (Shift), Smoke Effects
]]

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- KONFIGURASI
local MAX_SPEED = 120
local TURBO_SPEED = 200
local DRIFT_FRICTION = 0.25 
local NORMAL_FRICTION = 2.0
local DRIFT_POWER = 15 -- Kekuatan lemparan mobil saat ngepot

local player = game.Players.LocalPlayer
local isDrifting = false
local isTurbo = false

-- Fungsi untuk membuat partikel asap (Smoke)
local function createSmoke(wheel)
    if not wheel:FindFirstChild("DriftSmoke") then
        local smoke = Instance.new("ParticleEmitter")
        smoke.Name = "DriftSmoke"
        smoke.Texture = "rbxassetid://2521210785" -- Texture asap halus
        smoke.Lifetime = NumberRange.new(0.5, 1)
        smoke.Rate = 0
        smoke.Speed = NumberRange.new(5, 10)
        smoke.VelocitySpread = 30
        smoke.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 3)})
        smoke.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 1)})
        smoke.Parent = wheel
    end
end

RunService.RenderStepped:Connect(function()
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or not humanoid.SeatPart or not humanoid.SeatPart:IsA("VehicleSeat") then return end

    local seat = humanoid.SeatPart
    local car = seat.Parent

    -- 1. Logika Kecepatan & Turbo
    seat.MaxSpeed = isTurbo and TURBO_SPEED or MAX_SPEED

    -- 2. Logika Drift & Efek
    for _, part in pairs(car:GetDescendants()) do
        if part.Name == "Wheel" or part.Name == "Roda" or part:IsA("BasePart") and part.Size.Y == part.Size.Z then
            
            createSmoke(part)
            local smoke = part:FindFirstChild("DriftSmoke")

            if isDrifting and seat.Velocity.Magnitude > 20 then
                -- Membuat ban licin
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, DRIFT_FRICTION, 0.5)
                
                -- Efek Asap
                if smoke then smoke.Rate = 50 end

                -- Gaya dorong samping (Physics-based Drift)
                local driftForce = seat.CFrame.RightVector * (seat.Steer * DRIFT_POWER)
                seat.Velocity = seat.Velocity + (driftForce * 0.05)
            else
                -- Kembali Normal
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, NORMAL_FRICTION, 0.5)
                if smoke then smoke.Rate = 0 end
            end
        end
    end
end)

-- INPUT SISTEM
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.LeftShift then isDrifting = true end
    if input.KeyCode == Enum.KeyCode.E then isTurbo = true end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.LeftShift then isDrifting = false end
    if input.KeyCode == Enum.KeyCode.E then isTurbo = false end
end)
